generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Board {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  background  String   @default("#1d6fa4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lists       List[]
  members     BoardMember[]
}

model List {
  id        String   @id @default(cuid())
  title     String
  position  Float    @default(0)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Card {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  position    Float         @default(0)
  dueDate     DateTime?
  listId      String
  list        List          @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels      CardLabel[]
  checklists  Checklist[]
  assignments CardMember[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([listId])
}

model Label {
  id        String      @id @default(cuid())
  name      String
  color     String
  boardId   String?
  cards     CardLabel[]
  createdAt DateTime    @default(now())
}

model CardLabel {
  cardId  String
  labelId String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model Checklist {
  id        String          @id @default(cuid())
  title     String
  cardId    String
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now())

  @@index([cardId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  content     String
  completed   Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([checklistId])
}

model Member {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  avatarColor  String        @default("#4c9aff")
  initials     String
  boards       BoardMember[]
  cards        CardMember[]
  createdAt    DateTime      @default(now())
}

model BoardMember {
  boardId  String
  memberId String
  role     String  @default("member")
  board    Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  member   Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([boardId, memberId])
}

model CardMember {
  cardId   String
  memberId String
  card     Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([cardId, memberId])
}
